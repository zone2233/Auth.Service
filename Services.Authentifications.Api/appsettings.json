{
  "AllowedHosts": "*",


  "Serilog": {

    "Using": [ "Serilog.Sinks.File" ],

    "MinimumLevel": {

      "Default": "Information",

      "Override": {

        "System": "Information",

        "Microsoft": "Error",

        "Microsoft.EntityFrameworkCore": "Debug",

        "Microsoft.AspNetCore": "Information"

      }

    },

    "WriteTo": [

      {

        "Name": "File",

        "Args": {

          "path": "Logs\\logEmployees.txt",

          "outputTemplate": "[{Timestamp:HH:mm:ss.fff}] [{MachineName}] [{Level}] {Message}{NewLine}{Exception}",

          "rollOnFileSizeLimit": "true",

          "fileSizeLimitBytes": "20971520",

          "retainedFileCountLimit": "365",

          "rollingInterval": "Day",

          "shared": "true"

        }

      }

    ],


    "Properties": {

      "ApplicationName": "FirstApp"

    }

  },

  "Settings": {

    "ConnStrings": {
      "LocalDB": "Data Source=(localdb)\\mssqllocaldb;Initial Catalog=UsersApi;Trusted_Connection=True;MultipleActiveResultSets=true"

    },
    "JWTSettings": {
